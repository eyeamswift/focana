{
  "name": "focana",
  "version": "1.0.0",
  "description": "Desktop Focus App for ADHD",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "node scripts/patch-dev-plist.js && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "node scripts/patch-dev-plist.js && electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "vite build",
    "build:dir": "npm run build:renderer && electron-builder --dir",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:all": "npm run build:renderer && electron-builder -mwl",
    "build:mac:release": "npm run build:renderer && node scripts/mac-release.js full",
    "build:mac:notarize": "npm run build:renderer && node scripts/mac-release.js zip --require-notarization",
    "build:mac:notarize:full": "npm run build:renderer && node scripts/mac-release.js full --require-notarization",
    "build:mac:notarize:universal": "npm run build:renderer && node scripts/mac-release.js universal --require-notarization"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
