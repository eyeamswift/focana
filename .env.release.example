# macOS signing/notarization env vars for electron-builder
# Copy this to .env.release (ignored by git), then fill in your own values.
# Optional local overrides can go in .env.release.local.

# Team + app identity
APPLE_TEAM_ID=AFYKFD2QHU
APP_BUNDLE_ID=app.focana.desktop

# Preferred notarization via App Store Connect API key
APPLE_API_KEY_ID=V2VKXW4474
APPLE_API_ISSUER=6856ce3f-4db4-4c16-bcc3-84283f1a9019
APPLE_API_KEY_PATH=/Users/swift/Downloads/AuthKey_V2VKXW4474.p8

# Optional alternative to APPLE_API_KEY_PATH:
# APPLE_API_KEY="-----BEGIN PRIVATE KEY-----..."

# Optional if electron-builder cannot auto-detect cert:
# CSC_NAME="Developer ID Application: Your Name (AFYKFD2QHU)"
